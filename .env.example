# ============================================================
# Configuration RAG Enterprise
# Copier ce fichier en .env et remplir les valeurs :
#   cp .env.example .env
# ============================================================

# --- Environnement ---
# development | production
# En production, l'app refuse de démarrer si JWT_SECRET_KEY est
# faible ou si CORS_ORIGINS autorise toutes les origines.
ENV=development

# --- Sécurité (JWT) ---
# OBLIGATOIRE en production. Générer une clé forte avec :
#   openssl rand -hex 32
JWT_SECRET_KEY=
# Durée de validité d'un jeton, en minutes (défaut : 480 = 8 h)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS ---
# Origines autorisées, séparées par des virgules.
# En production, ne PAS utiliser '*'.
CORS_ORIGINS=http://localhost:8000,http://localhost:8001,http://127.0.0.1:8001

# --- LLM : Ollama (local, défaut) ---
# Modèle à utiliser : mistral | llama3 | llama3.2 | phi3
OLLAMA_MODEL=mistral
# URL du serveur Ollama. En local : http://localhost:11434
# En Docker (Ollama sur l'hôte) : http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM : OpenAI (fallback si machine insuffisante) ---
# Mettre USE_OPENAI=true pour basculer sur l'API OpenAI
USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini